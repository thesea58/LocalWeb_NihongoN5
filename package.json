{
  "name": "localweb-nihongo-n5",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create nihongo-user-data",
    "db:migrate": "wrangler d1 execute nihongo-user-data --remote --file=migrations/0001_user_storage.sql",
    "db:migrate:review": "wrangler d1 execute nihongo-user-data --remote --file=migrations/0002_review_tracking.sql",
    "user:sql": "node scripts/create-user.mjs",
    "check": "node --check worker/index.js && node --check scripts/create-user.mjs"
  },
  "devDependencies": {
    "wrangler": "4.107.0"
  }
}
